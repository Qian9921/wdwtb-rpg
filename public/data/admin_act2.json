{
  "career": "admin",
  "careerName": "高校行政",
  "act": 2,
  "actName": "上手",
  "start": "a2_start",
  "nodes": {
    "a2_start": {
      "speaker": "王主任",
      "text": "早啊。这摊事以后归你了——学籍异动、盖章、归档，一件都不能错。",
      "bg": "office_morning",
      "effects": {},
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_handover"
        }
      ]
    },
    "a2_handover": {
      "speaker": "王主任",
      "text": "他把一摞文件夹推到桌角，又放上一个磨掉漆的私章盒。你现在也是有章的人了。",
      "bg": "office_morning",
      "effects": {},
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_desk"
        }
      ]
    },
    "a2_desk": {
      "speaker": "",
      "text": "桌上第一次堆着我自己的待办。没人再兜底了。",
      "bg": "office_morning",
      "effects": {
        "performance": 2,
        "passion": 3
      },
      "choices": [
        {
          "text": "把文件夹一个个理清楚",
          "next": "a2_sort"
        }
      ]
    },
    "a2_sort": {
      "speaker": "",
      "text": "翻到一半，是王主任手画的流程图，旁边小字：此处最容易被退回。",
      "bg": "office_day",
      "effects": {
        "skill": 2
      },
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_colleague_in"
        }
      ]
    },
    "a2_colleague_in": {
      "speaker": "老同事",
      "text": "刘姐晃过来：哟，还真研究流程图。放宽心，做久了闭着眼都会。",
      "bg": "office_day",
      "effects": {},
      "choices": [
        {
          "text": "这些弯路能不能省掉几步?",
          "next": "a2_colleague_a",
          "note": "上进倾向初露"
        },
        {
          "text": "受教了,先照着做",
          "next": "a2_colleague_b",
          "note": "随大流"
        }
      ]
    },
    "a2_colleague_a": {
      "speaker": "老同事",
      "text": "刘姐笑了笑：能省早省了。这弯路不是给你走的，是给上头看的。",
      "bg": "office_day",
      "effects": {
        "san": -1,
        "skill": 1
      },
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_first_task"
        }
      ]
    },
    "a2_colleague_b": {
      "speaker": "",
      "text": "照着做最省事。可我总觉得，人会不会也变成流程图里的一个框。",
      "bg": "office_day",
      "effects": {
        "stress": 1
      },
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_first_task"
        }
      ]
    },
    "a2_first_task": {
      "speaker": "学生",
      "text": "一个男生趴在窗口：老师，我户籍证明的章今天必须办出来……求您了。",
      "bg": "office_window",
      "effects": {},
      "choices": [
        {
          "text": "别急,我看看能怎么帮你",
          "next": "a2_affairs_intro"
        }
      ]
    },
    "a2_affairs_intro": {
      "speaker": "",
      "text": "他材料缺一份、表格填错两处。按流程让他明天再来最省事，可他来不及了。",
      "bg": "office_window",
      "effects": {},
      "choices": [
        {
          "text": "帮他把这件事今天办成",
          "next": "a2_affairs_game"
        }
      ]
    },
    "a2_affairs_game": {
      "speaker": "",
      "text": "补表、跑签字、赶在窗口关门前——一步都不能错。",
      "bg": "office_window",
      "effects": {},
      "action": "minigame:affairs",
      "choices": [
        {
          "text": "开始",
          "next": "a2_affairs_done"
        }
      ]
    },
    "a2_affairs_done": {
      "speaker": "学生",
      "text": "章盖下去，男生眼圈红了：老师，谢谢……鞠了个躬，跑了。",
      "bg": "office_window",
      "effects": {
        "passion": 5,
        "skill": 3,
        "san": 2,
        "energy": -3
      },
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_affairs_after"
        }
      ]
    },
    "a2_affairs_after": {
      "speaker": "",
      "text": "一个红章，对我是流程里的一步，对他可能是一整年的学费。",
      "bg": "office_window",
      "effects": {},
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_wang_notice"
        }
      ]
    },
    "a2_wang_notice": {
      "speaker": "王主任",
      "text": "王主任放下报纸：今天这事，换我可能也就让他明天来。他没夸，可你听出那不是批评。",
      "bg": "office_day",
      "effects": {},
      "choices": [
        {
          "text": "我就是想帮他一把",
          "next": "a2_wang_reply_a"
        },
        {
          "text": "是不是我坏了规矩?",
          "next": "a2_wang_reply_b"
        }
      ]
    },
    "a2_wang_reply_a": {
      "speaker": "王主任",
      "text": "他嗯了一声：热情是好东西。就是——顿了顿，没说完。",
      "bg": "office_day",
      "effects": {
        "passion": 2
      },
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_bureaucracy_hit"
        }
      ]
    },
    "a2_wang_reply_b": {
      "speaker": "王主任",
      "text": "没坏，你把规矩用活了。但记住，能用活一次，不代表次次都行。",
      "bg": "office_day",
      "effects": {
        "skill": 1
      },
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_bureaucracy_hit"
        }
      ]
    },
    "a2_bureaucracy_hit": {
      "speaker": "",
      "text": "月底，一份汇总材料，核对了三遍，送去财务处。",
      "bg": "office_day",
      "effects": {},
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_reject_1"
        }
      ]
    },
    "a2_reject_1": {
      "speaker": "财务处",
      "text": "退回。抬头字号不对，该用三号仿宋，你用了小三。重打。",
      "bg": "corridor",
      "effects": {
        "stress": 2,
        "energy": -1
      },
      "choices": [
        {
          "text": "改字号,再送一次",
          "next": "a2_reject_2"
        }
      ]
    },
    "a2_reject_2": {
      "speaker": "财务处",
      "text": "又退回。落款日期该顶格、附件没编页码。数据没人看，先把格式弄对。",
      "bg": "corridor",
      "effects": {
        "stress": 2,
        "energy": -2,
        "passion": -2
      },
      "choices": [
        {
          "text": "第三遍,一个标点都对齐",
          "next": "a2_reject_3"
        }
      ]
    },
    "a2_reject_3": {
      "speaker": "财务处",
      "text": "过了。对方签了个名，内容一眼都没扫。你盯着磨掉的三个下午，说不出话。",
      "bg": "corridor",
      "effects": {},
      "choices": [
        {
          "text": "回工位,坐下",
          "next": "a2_reject_reflect"
        }
      ]
    },
    "a2_reject_reflect": {
      "speaker": "",
      "text": "数据没人管，字号错半号天塌下来。盖章的顺序真的比内容重要。",
      "bg": "office_dusk",
      "effects": {},
      "choices": [
        {
          "text": "找王主任聊两句",
          "next": "a2_wang_chat"
        },
        {
          "text": "找刘姐倒倒苦水",
          "next": "a2_colleague_philosophy"
        }
      ]
    },
    "a2_colleague_philosophy": {
      "speaker": "老同事",
      "text": "刘姐嗑了颗瓜子：退三遍算少的。诀窍就俩字——别较真。",
      "bg": "office_dusk",
      "effects": {},
      "choices": [
        {
          "text": "可这明明是在浪费所有人时间",
          "next": "a2_philo_push",
          "note": "上进不服"
        },
        {
          "text": "怎么才能不较真?",
          "next": "a2_philo_accept",
          "note": "开始被磨"
        }
      ]
    },
    "a2_philo_push": {
      "speaker": "老同事",
      "text": "浪费？这不叫浪费，这叫流程。你觉得亏，是因为你还把它当回事。",
      "bg": "office_dusk",
      "effects": {
        "san": -2,
        "passion": -1
      },
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_ceiling_setup"
        }
      ]
    },
    "a2_philo_accept": {
      "speaker": "老同事",
      "text": "把格式模板存一份，照抄。事还是那些事，你不难受了，就行了。",
      "bg": "office_dusk",
      "effects": {
        "skill": 2,
        "stress": -1,
        "passion": -2
      },
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_ceiling_setup"
        }
      ]
    },
    "a2_wang_chat": {
      "speaker": "王主任",
      "text": "王主任倒了杯茶：退三遍就受不住了？我年轻时候，也想干点不一样的。",
      "bg": "office_dusk",
      "effects": {
        "san": 1
      },
      "choices": [
        {
          "text": "那您后来呢?",
          "next": "a2_wang_story"
        }
      ]
    },
    "a2_wang_story": {
      "speaker": "王主任",
      "text": "后来我改过一版表格，精简了流程。上头说好，然后原封不动锁进了抽屉。",
      "bg": "office_dusk",
      "effects": {},
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_ceiling_setup"
        }
      ]
    },
    "a2_ceiling_setup": {
      "speaker": "",
      "text": "路过公示栏，一张晋升名单。轮到我提一级，得等六年。",
      "bg": "corridor_dusk",
      "effects": {},
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_ceiling_see"
        }
      ]
    },
    "a2_ceiling_see": {
      "speaker": "",
      "text": "再往后呢？就是王主任的位子。我好像一眼看到了六十岁的自己。",
      "bg": "corridor_dusk",
      "effects": {
        "san": -2,
        "passion": -2,
        "stress": 2
      },
      "choices": [
        {
          "text": "看到头,也是一种踏实",
          "next": "a2_ceiling_calm",
          "note": "自我安慰/随大流"
        },
        {
          "text": "看到头,反而有点慌",
          "next": "a2_ceiling_panic",
          "note": "不甘,上进伏笔"
        }
      ]
    },
    "a2_ceiling_calm": {
      "speaker": "",
      "text": "多少人求的就是这份看得到头。稳定是糖——甜久了舌头会发麻。",
      "bg": "corridor_dusk",
      "effects": {
        "stress": -1
      },
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_plant"
        }
      ]
    },
    "a2_ceiling_panic": {
      "speaker": "",
      "text": "才二十几岁，人生就被排进了队。稳定是糖，也是茧。",
      "bg": "corridor_dusk",
      "effects": {
        "passion": 1,
        "stress": 1
      },
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_plant"
        }
      ]
    },
    "a2_plant": {
      "speaker": "",
      "text": "回工位，窗台那盆绿植不声不响抽出了片新叶。",
      "bg": "office_night",
      "effects": {},
      "action": "plant_tree",
      "choices": [
        {
          "text": "给它浇点水",
          "next": "a2_plant_after"
        }
      ]
    },
    "a2_plant_after": {
      "speaker": "",
      "text": "它不管公示栏，不管六年还是十年。给点水和光，就自顾自地长。",
      "bg": "office_night",
      "effects": {
        "san": 2,
        "passion": 2,
        "stress": -1
      },
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_mindscape_gate"
        }
      ]
    },
    "a2_mindscape_gate": {
      "speaker": "",
      "text": "关灯前，抽屉里那封信硌了下手。要不要，往里看一眼？",
      "bg": "office_night",
      "effects": {},
      "choices": [
        {
          "text": "闭上眼,往心里走",
          "next": "a2_mindscape",
          "note": "进心象"
        },
        {
          "text": "算了,收拾东西回家",
          "next": "a2_letter_check",
          "note": "回避"
        }
      ]
    },
    "a2_mindscape": {
      "speaker": "",
      "text": "眼前退成了灰。一条望不到头的走廊，两边全是一模一样的门。",
      "bg": "mindscape",
      "effects": {},
      "action": "enter_mindscape",
      "choices": [
        {
          "text": "推开最近的一扇门",
          "next": "a2_mindscape_room"
        }
      ]
    },
    "a2_mindscape_room": {
      "speaker": "",
      "text": "门后是六十岁的我，给一株快枯的绿植浇水：别怕。这里很稳，稳到你会忘记本来想去哪。",
      "bg": "mindscape",
      "effects": {
        "san": -1
      },
      "choices": [
        {
          "text": "问他:我当初想去哪?",
          "next": "a2_mindscape_ask"
        }
      ]
    },
    "a2_mindscape_ask": {
      "speaker": "",
      "text": "他没答，把浇水壶递给我，壶身上有我写下的名字。醒来时，脸上有点凉。",
      "bg": "mindscape",
      "effects": {
        "passion": 3,
        "san": 1
      },
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_letter_check"
        }
      ]
    },
    "a2_letter_check": {
      "speaker": "",
      "text": "我把信抽出来，没拆。那句话，现在却像隔着半年在敲我。",
      "bg": "office_night",
      "effects": {},
      "choices": [
        {
          "text": "读信上那句话",
          "next": "a2_letter_read"
        }
      ]
    },
    "a2_letter_read": {
      "speaker": "",
      "text": "别让稳定把你想做的事磨没了。你是来生活的，不是来熬日子的。——只有一句是我当初圈住的。可现在，哪句都刺得慌。",
      "bg": "office_night",
      "effects": {
        "passion": 2,
        "san": -1
      },
      "choices": [
        {
          "text": "把信收回抽屉",
          "next": "a2_finale_setup"
        }
      ]
    },
    "a2_finale_setup": {
      "speaker": "王主任",
      "text": "王主任把文件放桌上：处里要选人牵头做全流程电子化试点。你可以试试，也可以不试。",
      "bg": "office_morning",
      "effects": {},
      "choices": [
        {
          "text": "(继续)",
          "next": "a2_finale_choice"
        }
      ]
    },
    "a2_finale_choice": {
      "speaker": "",
      "text": "这一步选什么，后面半年就长什么样。",
      "bg": "office_morning",
      "effects": {},
      "choices": [
        {
          "text": "接下试点——就算最后锁进抽屉,我也想改一次",
          "next": "a2_end_striver",
          "note": "上进:理想主义,可能碰壁但不甘平庸"
        },
        {
          "text": "婉拒——把手头的事做稳,别给自己添乱",
          "next": "a2_end_steady",
          "note": "随大流:安稳,代价是被磨平棱角"
        },
        {
          "text": "接,但先说好我的边界——下班就是下班",
          "next": "a2_end_boundary",
          "note": "边界:清醒,守住生活不被工作吞掉"
        }
      ]
    },
    "a2_end_striver": {
      "speaker": "",
      "text": "我签了字。王主任嘴角动了下，像想起了那个锁进抽屉的自己。",
      "bg": "office_morning",
      "effects": {
        "passion": 4,
        "stress": 3,
        "skill": 2,
        "energy": -2
      },
      "action": "next_act",
      "note": "上进结局:热情高企,压力抬升,埋第3幕理想碰壁伏笔",
      "choices": []
    },
    "a2_end_steady": {
      "speaker": "",
      "text": "我把文件推了回去：还是先把手头的做扎实。他点点头，没多说。",
      "bg": "office_morning",
      "effects": {
        "passion": -3,
        "stress": -2,
        "san": -1,
        "performance": 2
      },
      "action": "next_act",
      "note": "随大流结局:趋稳,热情走低,埋第3幕被磨平/温水伏笔",
      "choices": []
    },
    "a2_end_boundary": {
      "speaker": "",
      "text": "我接了，也说清了：五点半我准时走。王主任笑了：这话，我年轻时候没敢说。",
      "bg": "office_morning",
      "effects": {
        "passion": 2,
        "stress": -1,
        "san": 3,
        "health": 2
      },
      "action": "next_act",
      "note": "边界结局:清醒自守,身心回正,埋第3幕工作与生活拉扯伏笔",
      "choices": []
    }
  }
}
